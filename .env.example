# ─── API Votes (Cloudflare Worker) ───────────────────────────────────────────
# Copier ce fichier en .env et remplir l'URL après déploiement du Worker.
#
# Étapes :
#   1. cd ../fluxup-votes
#   2. npm install
#   3. npm run db:create        → noter le database_id → wrangler.toml
#   4. npm run kv:create        → noter le kv id      → wrangler.toml
#   5. npm run db:migrate
#   6. npm run deploy           → noter l'URL du Worker ci-dessous
#
VITE_VOTES_API_URL=https://fluxup-votes-api.<ton-subdomain>.workers.dev
